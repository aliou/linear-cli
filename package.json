{
  "name": "linear-cli",
  "version": "0.4.0",
  "description": "CLI for Linear via GraphQL API",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "linear": "src/index.ts"
  },
  "files": [
    "src/",
    "schemas/",
    "SKILL.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun run scripts/build.ts",
    "changeset": "changeset",
    "version": "bun run scripts/version.ts"
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.4.1",
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "cli-table3": "^0.6.5",
    "commander": "14.0.3",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  }
}
